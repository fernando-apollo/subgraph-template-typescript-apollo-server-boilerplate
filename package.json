{
  "name": "subgraph-template-typescript-apollo-server",
  "private": true,
  "description": "Apollo Federation subgraph template using TypeScript and Apollo Server",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/apollographql/subgraph-template-typescript-apollo-server"
  },
  "homepage": "https://github.com/apollographql/subgraph-template-typescript-apollo-server#readme",
  "bugs": {
    "url": "https://github.com/apollographql/subgraph-template-typescript-apollo-server/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "build": "npm run codegen && tsc",
    "codegen": "graphql-codegen",
    "postinstall": "npm run build",
    "start": "node dist/index.js",
    "dev": "nodemon --watch \"src/**\" --ext \"ts,json,graphql\" --exec \"npm run build && npm run start\" --ignore ./src/__generated__/",
    "test": "jest"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@apollo/subgraph": "^2.13.2",
    "graphql": "^16.13.1",
    "graphql-tag": "^2.12.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/typescript": "^5.0.0",
    "@graphql-codegen/typescript-resolvers": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "jest": "^30.0.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "src"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  }
}
